<comment>
problem = Hydro setup with constant density and pressure

<job>
problem_id = decaying_turbulence

<parthenon/output1>
file_type  = hst        # History data dump
dt         = 0.01       # time increment between outputs

<parthenon/output2>
file_type  = hdf5       # Binary data dump
variables   = prim,acc   # variables to be output
dt         = 1.0        # time increment between outputs
id         = prim
single_precision_output = true

<parthenon/output3>
file_type  = rst        # Binary data dump
dt         = 1.0        # time increment between outputs
id         = restart

<parthenon/output4>
file_type         = openpmd
dt                = 0.1        # frequency of outputs
id                = sl.x1.0.5   # arb. id for easy identification
output_type       = x1slice     # fixed axis of slice. Options: x1slice, x2slice, x3slice
slice_loc         = 0.5         # location of the slice

<parthenon/output5>
file_type = spectrum
variable = cons
components = 5, 6, 7
output_label = B
dt = 0.1

<parthenon/output6>
file_type = spectrum
variable = cons
components = 1, 2, 3
output_label = v
dt = 0.1

<problem/stochastic_B_field>
rho0 = 1.0
p0   = 1.0
vx   = 0.0
vy   = 0.0
vz   = 0.0
kmax = 16.0	# Largest allowed mode in units of 2*pi/L_x where L_x is the box size as defined under <mesh>
		# This should be <= min(nx1, nx2, nx3)
B_rms = 1.0

# Double Power-law power  Spectrum params:
kI = 3.0	# Power Spectrum peak in units of 2*pi/L 
n1 = 4.0	# power law index such that P ~ k^(n1) for k << kI
n2 = 1.6666666666666667	# Power law index such that P ~ k^(-n2) for k >> KI
alpha = 1000.0	# Controls the sharpness of the transition between the two power laws

helicity = 0.0 # Helicity fraction (between -1 and 1)

<refinement>
type                     = maxdensity
maxdensity_deref_below   = 1.00005
maxdensity_refine_above  = 1.0001

<parthenon/mesh>
refinement = none
nghost = 3

nx1 = 32
x1min = -3.141593
x1max = 3.141593
#x1min = -1.
#x1max = 1.
ix1_bc = periodic
ox1_bc = periodic

nx2 = 32
x2min = -3.141593
x2max = 3.141593
#x2min = -1.
#x2max = 1.
ix2_bc = periodic
ox2_bc = periodic

nx3 = 32
x3min = -3.141593
x3max = 3.141593
#x3min = -1.
#x3max = 1.
ix3_bc = periodic
ox3_bc = periodic

<parthenon/meshblock>
nx1=16
nx2=16
nx3=16

<parthenon/time>
integrator = vl2
cfl = 0.3
tlim = 20.0
nlim = 100000
perf_cycle_offset = 2 # number of inital cycles not to be included in perf calc
ncycle_out_mesh = -1000

<hydro>
fluid = glmmhd
eos = adiabatic
riemann = hlld
first_order_flux_correct = true
reconstruction = ppm
gamma = 1.0001 # gamma = C_p/C_v (makes the EOS approimately isothermal, P ~ rho) 
scratch_level = 0 # 0 is actual scratch (tiny); 1 is HBM
# pressure_floor = 1e-6 # these should not be necessary.
# e_floor = 1e-6

#<diffusion>
#integrator = unsplit 
#conduction = none
#conduction_coeff = fixed
#thermal_diff_coeff_code = 0.0
#viscosity = isotropic            # none (disabled), isotropic, or anisotropic
#viscosity_coeff = fixed
#mom_diff_coeff_code = 0.00005
#resistivity = ohmic          # none (disabled) or ohmic
#resistivity_coeff = fixed
#ohm_diff_coeff_code = 0.00005
#rkl2_max_dt_ratio = 100.0
